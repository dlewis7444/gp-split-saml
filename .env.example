# GlobalProtect gateway hostname
VPN_GATEWAY=vpn.example.com

# VPN-side DNS server
VPN_DNS=10.0.0.1

# Domains routed through VPN DNS (space-separated, ~ prefix = route-only, not search)
VPN_DOMAINS="~corp.example.com ~internal.example.com"

# Internal network CIDR routed through the VPN tunnel
VPN_INTERNAL_ROUTE=10.0.0.0/8

# Home network DNS server and domain.
# If commented out, the script auto-detects from the current interface state.
#HOME_DNS=192.168.1.1
#HOME_DOMAIN=home.local
